aws_region = "us-east-1"
project_name = "devops-seguimiento3"
environment = "dev"

database_name = "academia"
database_username = "postgres"
database_password = "YourSecurePassword123!"
database_port = 5432

lambda_function_name = "api-seguimiento1"
artifact_path = "../dist/function.zip"

allowed_ssh_cidr = "0.0.0.0/0"

# Optional: existing EC2 key pair name used by the bastion.
# Create/import it in AWS first, then set this value.
bastion_key_name = "my-bastion-key"

# Optional: import a local public key into AWS as the bastion key pair instead.
# Generate the pair locally with ssh-keygen and point this to the .pub file.
bastion_public_key_path = "C:/Users/you/.ssh/id_rsa.pub"

# OPTIONAL: provide AWS credentials here only if you cannot use env vars, shared credentials file or IAM roles.
# Copy this file to terraform/terraform.tfvars and fill values. DO NOT COMMIT terraform/terraform.tfvars
aws_access_key = "AKIA...."
aws_secret_key = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYzEXAMPLEKEY"

